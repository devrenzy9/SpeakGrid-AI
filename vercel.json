{
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node",
      "config": {
        "outputDirectory": "client/dist",
        "includeFiles": ["server/**"],
        "nodeModules": true
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/audio/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/(.*\\.(?:js|css|png|jpg|jpeg|gif|svg|ico|webp|woff2|woff|ttf|json|avif|cmap))",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
